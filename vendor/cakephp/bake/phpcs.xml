<?xml version="1.0"?>
<ruleset name="CakePHP Bake">
    <arg value="ns"/>

    <file>src/</file>
    <file>tests/</file>

    <rule ref="CakePHP" />
    <arg value="nps"/>
    <arg name="colors"/>
    <arg name="parallel" value="4"/>
    <arg name="cache" value=".phpcs.cache"/>

    <exclude-pattern>*/comparisons/*</exclude-pattern>
    <exclude-pattern>tests/test_app/*</exclude-pattern>
</ruleset>
